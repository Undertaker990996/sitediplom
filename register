<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Регистрация - БКРБ</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #0a5c7e 0%, #17a2b8 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            padding: 40px 0;
        }
        .register-card {
            background: white;
            border-radius: 20px;
            padding: 40px;
            width: 100%;
            max-width: 600px;
            margin: 0 auto;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .register-card h2 {
            color: #0a5c7e;
            text-align: center;
            margin-bottom: 10px;
        }
        .register-card .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 14px;
        }
        .form-control, .form-select {
            border-radius: 10px;
            padding: 10px 15px;
            border: 1px solid #ddd;
        }
        .form-control:focus, .form-select:focus {
            border-color: #0a5c7e;
            box-shadow: 0 0 0 0.2rem rgba(10,92,126,0.25);
        }
        .btn-register {
            background: #0a5c7e;
            border: none;
            border-radius: 30px;
            padding: 12px;
            font-weight: bold;
            width: 100%;
            color: white;
        }
        .btn-register:hover {
            background: #084a66;
        }
        .form-section {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
        }
        .form-section h5 {
            color: #0a5c7e;
            margin-bottom: 15px;
            font-size: 16px;
        }
        .required:after {
            content: " *";
            color: red;
        }
        .password-hint {
            font-size: 12px;
            color: #666;
            margin-top: 5px;
        }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="text-center">
            <i class="fas fa-hospital fa-3x" style="color: #0a5c7e;"></i>
        </div>
        <h2>🏥 БКРБ</h2>
        <div class="subtitle">Регистрация в системе</div>
        
        <form id="registerForm">
            <!-- Личные данные -->
            <div class="form-section">
                <h5><i class="fas fa-user-circle me-2"></i> Личные данные</h5>
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label required">Фамилия</label>
                        <input type="text" id="last_name" class="form-control" placeholder="Иванов" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label required">Имя</label>
                        <input type="text" id="first_name" class="form-control" placeholder="Иван" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Отчество</label>
                        <input type="text" id="middle_name" class="form-control" placeholder="Иванович">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Дата рождения</label>
                        <input type="date" id="birth_date" class="form-control">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Полис ОМС</label>
                        <input type="text" id="policy_number" class="form-control" placeholder="1234 567890 12" required>
                    </div>
                </div>
            </div>
            
            <!-- Контактные данные -->
            <div class="form-section">
                <h5><i class="fas fa-address-card me-2"></i> Контактные данные</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">Телефон</label>
                        <input type="tel" id="phone" class="form-control" placeholder="+7(916)123-45-67" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Email</label>
                        <input type="email" id="email" class="form-control" placeholder="ivan@mail.ru" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">Адрес проживания</label>
                        <textarea id="address" class="form-control" rows="2" placeholder="г. Москва, ул. Ленина, д. 10, кв. 5"></textarea>
                    </div>
                </div>
            </div>
            
            <!-- Данные для входа -->
            <div class="form-section">
                <h5><i class="fas fa-lock me-2"></i> Данные для входа</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label required">Логин</label>
                        <input type="text" id="username" class="form-control" placeholder="ivan_petrov" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Пароль</label>
                        <input type="password" id="password" class="form-control" placeholder="Не менее 6 символов" required>
                        <div class="password-hint">Пароль должен содержать не менее 6 символов</div>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label required">Подтверждение пароля</label>
                        <input type="password" id="confirm_password" class="form-control" placeholder="Повторите пароль" required>
                    </div>
                </div>
            </div>
            
            <!-- Дополнительная информация -->
            <div class="form-section">
                <h5><i class="fas fa-notes-medical me-2"></i> Дополнительная информация</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Группа крови</label>
                        <select id="blood_type" class="form-select">
                            <option value="">Не указано</option>
                            <option value="I(I)">I (I) положительная</option>
                            <option value="I(II)">I (I) отрицательная</option>
                            <option value="II(I)">II (A) положительная</option>
                            <option value="II(II)">II (A) отрицательная</option>
                            <option value="III(I)">III (B) положительная</option>
                            <option value="III(II)">III (B) отрицательная</option>
                            <option value="IV(I)">IV (AB) положительная</option>
                            <option value="IV(II)">IV (AB) отрицательная</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Аллергии</label>
                        <input type="text" id="allergies" class="form-control" placeholder="Например: пенициллин, пыльца">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Хронические заболевания</label>
                        <textarea id="chronic_diseases" class="form-control" rows="2" placeholder="Перечислите хронические заболевания, если есть"></textarea>
                    </div>
                </div>
            </div>
            
            <!-- Согласие -->
            <div class="form-check mb-3">
                <input class="form-check-input" type="checkbox" id="agree" required>
                <label class="form-check-label" for="agree">
                    Я соглашаюсь на обработку персональных данных и принимаю условия <a href="#">пользовательского соглашения</a>
                </label>
            </div>
            
            <button type="submit" class="btn-register"><i class="fas fa-user-plus me-2"></i> Зарегистрироваться</button>
        </form>
        
        <hr class="my-4">
        <p class="text-center mb-0">Уже есть аккаунт? <a href="login.html">Войти</a></p>
    </div>

    <script>
        document.getElementById('registerForm').addEventListener('submit', function(e) {
            e.preventDefault();
            
            const password = document.getElementById('password').value;
            const confirm = document.getElementById('confirm_password').value;
            
            if (password !== confirm) {
                alert('Пароли не совпадают!');
                return;
            }
            
            if (password.length < 6) {
                alert('Пароль должен быть не менее 6 символов!');
                return;
            }
            
            // Собираем данные
            const formData = {
                last_name: document.getElementById('last_name').value,
                first_name: document.getElementById('first_name').value,
                middle_name: document.getElementById('middle_name').value,
                birth_date: document.getElementById('birth_date').value,
                policy_number: document.getElementById('policy_number').value,
                phone: document.getElementById('phone').value,
                email: document.getElementById('email').value,
                address: document.getElementById('address').value,
                username: document.getElementById('username').value,
                blood_type: document.getElementById('blood_type').value,
                allergies: document.getElementById('allergies').value,
                chronic_diseases: document.getElementById('chronic_diseases').value
            };
            
            console.log('Регистрация:', formData);
            
            // Показываем сообщение об успехе
            alert('Регистрация успешна! Теперь вы можете войти в систему.');
            window.location.href = 'login.html';
        });
    </script>
</body>
</html>
